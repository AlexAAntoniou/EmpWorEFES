                    <lb n="8"/><name>Cissi</name></persName> <g ref="interpunct">·</g> <expan><abbr>lib</abbr><ex>erti</ex></expan>
                    <lb n="9"/><persName type="attested"><name><expan><abbr>M</abbr><ex>arcus</ex></expan></name> <g ref="interpunct">·</g> <name>Trosius</name>
                    <lb n="10"/><name>Modestus</name></persName>
                    <lb n="11"/><expan><abbr>d</abbr><ex>onum</ex></expan> <expan><abbr>d</abbr><ex>edit</ex></expan>
