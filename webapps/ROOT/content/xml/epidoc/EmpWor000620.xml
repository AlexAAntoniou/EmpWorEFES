                <ab>
                    <lb n="1"/><persName type="divine" key="silvanusAugustus"><name>Silvano</name>
                    <lb n="2"/><name><expan><abbr>Aug</abbr><ex>usto</ex></expan></name></persName>
                    <lb n="3"/>in <g ref="interpunct">·</g> <expan><abbr>honor</abbr><ex>em</ex></expan>
                    <lb n="4"/><persName type="attested"><name><expan><abbr>M</abbr><ex>arci</ex></expan></name> <g ref="interpunct">·</g> <name>Trosi</name>
                    <lb n="5"/><name>Daphni</name></persName>
                    <lb n="6"/><num value="6">I<hi rend="supraline">IIII</hi>I</num><g ref="interpunct">·</g>viri 
